+#ifndef GCC_RISCV_MINIX_H
+#define GCC_RISCV_MINIX_H
+
+/* MINIX keeps the historical 64-bit long double ABI on RISC-V.  */
+#undef LONG_DOUBLE_TYPE_SIZE
+#define LONG_DOUBLE_TYPE_SIZE 64
+
+/* Advertise soft-float mode to the headers when requested.  */
+#undef MINIX_TARGET_CPU_CPP_BUILTINS
+#define MINIX_TARGET_CPU_CPP_BUILTINS() \
+  do \
+    { \
+      if (!TARGET_HARD_FLOAT_ABI) \
+        builtin_define ("_SOFT_FLOAT"); \
+    } \
+  while (0)
+
+#endif /* GCC_RISCV_MINIX_H */
