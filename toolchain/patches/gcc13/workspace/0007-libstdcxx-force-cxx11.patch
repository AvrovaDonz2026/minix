--- a/external/gpl3/gcc/lib/libstdc++-v3/Makefile
+++ b/external/gpl3/gcc/lib/libstdc++-v3/Makefile
@@ -19,6 +19,10 @@
 
 CXXFLAGS.clang+=	-stdlib=libstdc++ -std=c++11 -D_GLIBCXX_ABI_TAG_CXX11=
 CXXFLAGS+=	${CXXFLAGS.${ACTIVE_CC}}
+
+# GCC13 libstdc++ sources require a modern baseline (eh_alloc/string_view,
+# relaxed constexpr rules, etc.) in libsupc++ paths.
+CXXFLAGS+=	-std=gnu++17
 CWARNFLAGS.clang+=	-Wno-logical-op-parentheses \
 			-Wno-deprecated-writable-strings -Wno-parentheses
 
@@ -48,6 +52,9 @@
 CPPFLAGS+=	-I${.CURDIR}/arch/${LIBSTDCXX_MACHINE_ARCH}
 # include backwards compatible code
 CPPFLAGS+=     -D_GLIBCXX_SHARED -DGTHREAD_USE_WEAK -DSUPPORTS_WEAK
+# GCC13 ginclude/stddef.h can define BSD typedef macros as empty.
+# Seed them explicitly and mark size_t/ptrdiff_t as already declared.
+CPPFLAGS+=     -D_BSD_SIZE_T_=__SIZE_TYPE__ -D_BSD_SIZE_T_DEFINED_=1 -D_BSD_PTRDIFF_T_=__PTRDIFF_TYPE__ -D_BSD_PTRDIFF_T_DEFINED_=1
 
 CONF=		${DIST}/libstdc++-v3/config
 
@@ -70,6 +77,9 @@
 # XXX also need this for some PCHs.
 CPPFLAGS.atomic.cc = -std=gnu++0x
 CPPFLAGS.compatibility-c++0x.cc = -std=gnu++0x
+
+# Keep compatibility-c++0x immune to empty _BSD_SIZE_T_ regressions.
+CPPFLAGS.compatibility-c++0x.cc += -D_BSD_SIZE_T_=__SIZE_TYPE__ -D_BSD_SIZE_T_DEFINED_=1
 CPPFLAGS.functexcept.cc+= -std=gnu++0x
 CPPFLAGS.hash_c++0x.cc = -std=gnu++0x
 CPPFLAGS.hashtable_c++0x.cc = -std=gnu++0x
@@ -84,6 +94,21 @@
 CPPFLAGS.thread.cc = -std=gnu++0x
 CPPFLAGS.future.cc = -std=gnu++0x
 
+# GCC13 moves these c++98 sources to at least C++11 semantics.
+CPPFLAGS.locale_init.cc += -std=gnu++11
+CPPFLAGS.localename.cc += -std=gnu++11
+
+# GCC13 keeps legacy throw(...) signatures in this TU.
+CPPFLAGS.bitmap_allocator.cc += -std=gnu++98
+
+# Keep this legacy TU on C++98; it trips over newer dialect defaults.
+CPPFLAGS.misc-inst.cc += -std=gnu++98
+
+# GCC13 + C++17 trips over legacy safe-bool template-id forms.
+CPPFLAGS.ios_locale.cc += -std=gnu++98
+CPPFLAGS.ios_failure.cc += -std=gnu++98
+CPPFLAGS.ios_init.cc += -std=gnu++98
+
 CPPFLAGS.cp-demangle.cc += -DIN_GLIBCPP_V3
 CPPFLAGS.concept-inst.cc += -D_GLIBCXX_CONCEPT_CHECKS
 CPPFLAGS.parallel_list.cc += -D_GLIBCXX_PARALLEL

--- a/external/gpl3/gcc/lib/libsupc++/Makefile.common
+++ b/external/gpl3/gcc/lib/libsupc++/Makefile.common
@@ -20,4 +20,8 @@
 CPPFLAGS+=	-I${DIST}/libstdc++-v3/libsupc++
 CPPFLAGS+=	-I${DIST}/libgcc
 CPPFLAGS+=	-I${.CURDIR}/../libstdc++-v3/arch/${LIBSTDCXX_MACHINE_ARCH} -I.
+# GCC13 adds headers (e.g. debug/assertions.h) that are absent from
+# the legacy installed include set during early libsupc++ build.
+CPPFLAGS+=	-I${DIST}/libstdc++-v3/include
+CPPFLAGS+=	-I${DIST}/libstdc++-v3/include/debug
 CPPFLAGS+=	-DHAVE_STDLIB_H -DHAVE_STRING_H
