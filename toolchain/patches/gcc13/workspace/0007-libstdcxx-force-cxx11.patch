--- a/external/gpl3/gcc/lib/libstdc++-v3/Makefile
+++ b/external/gpl3/gcc/lib/libstdc++-v3/Makefile
@@ -19,6 +19,10 @@
 
 CXXFLAGS.clang+=	-stdlib=libstdc++ -std=c++11 -D_GLIBCXX_ABI_TAG_CXX11=
 CXXFLAGS+=	${CXXFLAGS.${ACTIVE_CC}}
+
+# GCC13 libstdc++ sources require a modern baseline (eh_alloc/string_view,
+# relaxed constexpr rules, etc.) in libsupc++ paths.
+CXXFLAGS+=	-std=gnu++17
 CWARNFLAGS.clang+=	-Wno-logical-op-parentheses \
 			-Wno-deprecated-writable-strings -Wno-parentheses
 
@@ -70,6 +74,9 @@
 # XXX also need this for some PCHs.
 CPPFLAGS.atomic.cc = -std=gnu++0x
 CPPFLAGS.compatibility-c++0x.cc = -std=gnu++0x
+
+# GCC13 ginclude/stddef.h can leave _BSD_SIZE_T_ empty in this TU.
+CPPFLAGS.compatibility-c++0x.cc += -D_BSD_SIZE_T_=__SIZE_TYPE__ -D_BSD_SIZE_T_DEFINED_=1
 CPPFLAGS.functexcept.cc+= -std=gnu++0x
 CPPFLAGS.hash_c++0x.cc = -std=gnu++0x
 CPPFLAGS.hashtable_c++0x.cc = -std=gnu++0x
@@ -84,6 +91,13 @@
 CPPFLAGS.thread.cc = -std=gnu++0x
 CPPFLAGS.future.cc = -std=gnu++0x
 
+# GCC13 moves these c++98 sources to at least C++11 semantics.
+CPPFLAGS.locale_init.cc += -std=gnu++11
+CPPFLAGS.localename.cc += -std=gnu++11
+
+# Keep this legacy TU on C++98; it trips over newer dialect defaults.
+CPPFLAGS.misc-inst.cc += -std=gnu++98
+
 CPPFLAGS.cp-demangle.cc += -DIN_GLIBCPP_V3
 CPPFLAGS.concept-inst.cc += -D_GLIBCXX_CONCEPT_CHECKS
 CPPFLAGS.parallel_list.cc += -D_GLIBCXX_PARALLEL
