--- a/external/gpl3/gcc/lib/libstdc++-v3/Makefile
+++ b/external/gpl3/gcc/lib/libstdc++-v3/Makefile
@@ -52,7 +52,11 @@
 
 CONF=		${DIST}/libstdc++-v3/config
 
+.if ${GCC13_SPIKE:Uno} == "yes"
+GLIBCPP_INCLUDE_DIR=	${DIST}/libstdc++-v3/include
+.else
 GLIBCPP_INCLUDE_DIR=	${DESTDIR}/usr/include/g++
+.endif
 
 # Template instantiation bug workaround for -O<2/s
 COPTS.cp-demangle.c = -Wno-stack-protector
--- a/external/gpl3/gcc/lib/libsupc++/Makefile.common
+++ b/external/gpl3/gcc/lib/libsupc++/Makefile.common
@@ -22,9 +22,15 @@
 CPPFLAGS+=	-I${.CURDIR}/../libstdc++-v3/arch/${LIBSTDCXX_MACHINE_ARCH} -I.
 CPPFLAGS+=	-DHAVE_STDLIB_H -DHAVE_STRING_H
 
-.if defined(__MINIX)
+.if defined(__MINIX) && ${GCC13_SPIKE:Uno} != "yes"
 CPPFLAGS+=	-I${DESTDIR}/usr/include/g++
 CPPFLAGS+=	-I${DESTDIR}/usr/include/gcc-4.8
+.elif ${GCC13_SPIKE:Uno} == "yes"
+# Keep GCC13 libsupc++/libstdc++ self-hosted against the overlaid source
+# headers. Mixing in DESTDIR's legacy GCC4-era include trees leaves string
+# and ios types incomplete during the bootstrap build.
+CPPFLAGS+=	-I${DIST}/libstdc++-v3/include
+CPPFLAGS+=	-I${DIST}/libstdc++-v3/include/debug
 .endif #defined(__MINIX)
 
 CPPFLAGS.cp-demangle.c=-DIN_GLIBCPP_V3
