--- a/external/gpl3/gcc/lib/libsupc++/Makefile.common	2026-03-07 12:19:48.856828600 +0800
+++ b/external/gpl3/gcc/lib/libsupc++/Makefile.common	2026-03-07 12:19:48.892828746 +0800
@@ -22,8 +22,9 @@
 CPPFLAGS+=	-I${DIST}/libgcc
 CPPFLAGS+=	-I${.CURDIR}/../libstdc++-v3/arch/${LIBSTDCXX_MACHINE_ARCH} -I.
 # GCC13 adds headers (e.g. debug/assertions.h) that are absent from
 # the legacy installed include set during early libsupc++ build.
+# Use the source include root for <debug/...>; adding include/debug itself
+# shadows public wrappers such as <string> with debug/string.
 CPPFLAGS+=	-I${DIST}/libstdc++-v3/include
-CPPFLAGS+=	-I${DIST}/libstdc++-v3/include/debug
 CPPFLAGS+=	-DHAVE_STDLIB_H -DHAVE_STRING_H
 
 .if defined(__MINIX) && ${GCC13_SPIKE:Uno} != "yes"
@@ -41,7 +42,6 @@
 CPPFLAGS+=	-I${DIST}/libstdc++-v3/include/std
 CPPFLAGS+=	-I${DIST}/libstdc++-v3/include/c_global
 CPPFLAGS+=	-I${DIST}/libstdc++-v3/include
-CPPFLAGS+=	-I${DIST}/libstdc++-v3/include/debug
 # Force libsupc++ and the libstdc++ sources that include this common
 # fragment onto GCC13's dual-ABI/C++11 path.
 CPPFLAGS+=	-U_GLIBCXX_USE_DUAL_ABI -D_GLIBCXX_USE_DUAL_ABI=1
