--- a/external/gpl3/gcc/usr.bin/backend/Makefile
+++ b/external/gpl3/gcc/usr.bin/backend/Makefile
@@ -18,6 +18,18 @@
 
 HOSTPROG_CXX=	1
 
+# bsd.lib.mk pulls in ../Makefile.inc via bsd.init.mk, but the early .PATH
+# seed below and G_out_file-based GCC13 source fallback must not expand
+# before DIST/GCCARCH/G_out_file are defined.
+.include "../Makefile.inc"
+
+# 0018 seeds G_OUT_FILE_SRC before Makefile.inc exists. Recompute it here once
+# G_out_file is available so GCC13 backend targets can switch .c -> .cc.
+G_OUT_FILE_SRC=	${G_out_file}
+.if !exists(${G_out_file}) && exists(${G_out_file:S,.c,.cc,})
+G_OUT_FILE_SRC:=	${G_out_file:S,.c,.cc,}
+.endif
+
 .include <bsd.lib.mk>
 
 # Force using C++ for this
